global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alerts.yml

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - alertmanager:9093

scrape_configs:
  - job_name: banking-platform-api
    metrics_path: /api/metrics
    scheme: http
    authorization:
      type: Bearer
      credentials: '${PROMETHEUS_METRICS_BEARER_TOKEN}'
    static_configs:
      - targets:
          - '${PROMETHEUS_METRICS_TARGET}'
        labels:
          service: banking-platform-api
          environment: local
