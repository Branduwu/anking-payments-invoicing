NODE_ENV=development
APP_NAME=banking-platform-api
PORT=4000
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000

COOKIE_NAME=__Host-session
COOKIE_SECRET=replace-with-a-32-char-minimum-secret
COOKIE_SECURE=false

SESSION_IDLE_TIMEOUT_MINUTES=15
SESSION_ABSOLUTE_TIMEOUT_HOURS=8
REAUTH_WINDOW_MINUTES=5

DATABASE_URL=postgresql://platform:platform@localhost:5432/platform
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=platform

AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
MFA_SETUP_TTL_MINUTES=10
MFA_VERIFY_MAX_ATTEMPTS=5
MFA_VERIFY_WINDOW_MINUTES=10
MFA_VERIFY_LOCKOUT_MINUTES=15
MFA_ENCRYPTION_KEY=replace-with-a-32-char-minimum-mfa-secret
AUDIT_FAIL_CLOSED_DEFAULT=false
AUDIT_FAIL_CLOSED_ACTION_PREFIXES=sessions.,payments.create.success,invoices.create.success,invoices.stamp.success,invoices.cancel.success,auth.mfa.setup.created,auth.mfa.verify.success,auth.mfa.recovery_codes.regenerated,auth.mfa.disabled,auth.mfa.admin_reset.success
ALLOW_DEGRADED_STARTUP=false

PAC_PROVIDER=mock
PAC_BASE_URL=
PAC_API_KEY=
PAC_TIMEOUT_MS=10000
PAC_ALLOW_MOCK_IN_PRODUCTION=false

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMeNow_123456789!
ADMIN_NAME=Platform Admin
ADMIN_MFA_TOTP_CODE=
ADMIN_MFA_RECOVERY_CODE=
